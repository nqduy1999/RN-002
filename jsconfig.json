{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@/*": ["./*"],
      "@assets/*": ["./assets/*"],
      "@common/*": ["./common/*"],
      "@hooks/*": ["./hooks/*"],
      "@constants/*": ["./constants/*"],
      "@resources/*": ["./resources/*"],
      "@redux/*": ["./redux/*"]
    },
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false
  },
  "include": ["**/*.js", "**/*.jsx", ".expo/types/**/*.js"]
}
